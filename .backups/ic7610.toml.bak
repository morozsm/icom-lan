# Rig Configuration — IC-7610
# This file defines the IC-7610 radio profile in TOML format.
# See _schema.md for field documentation.

[radio]
id = "icom_ic7610"
model = "IC-7610"
civ_addr = 0x98
default_baud = 115200
receiver_count = 2
has_lan = true
has_wifi = false

[spectrum]
seq_max = 11
amp_max = 160
data_len_max = 475

[capabilities]
features = [
    "audio",
    "scope",
    "dual_rx",
    "meters",
    "tx",
    "cw",
    "attenuator",
    "preamp",
    "rf_gain",
    "af_level",
    "squelch",
    "nb",
    "nr",
    "digisel",
    "ip_plus",
]

[attenuator]
values = [0, 6, 12, 18]  # 0=OFF, 6/12/18 dB

[preamp]
values = [0, 1, 2]  # 0=OFF, 1=PRE1, 2=PRE2

[agc]
modes = [1, 2, 3]  # 1=FAST, 2=MID, 3=SLOW
labels = { "1" = "FAST", "2" = "MID", "3" = "SLOW" }

[modes]
list = ["USB", "LSB", "CW", "CW-R", "AM", "FM", "RTTY", "RTTY-R"]

[filters]
list = ["FIL1", "FIL2", "FIL3"]

[vfo]
scheme = "main_sub"
main_select = [0xD0]
sub_select = [0xD1]
swap = [0xB0]

# ── Frequency Ranges ─────────────────────────────────────────────

[[freq_ranges.ranges]]
label = "HF"
start_hz = 30_000
end_hz = 60_000_000

[[freq_ranges.ranges.bands]]
name = "160m"
start_hz = 1_800_000
end_hz = 2_000_000
default_hz = 1_825_000
bsr_code = 0x01

[[freq_ranges.ranges.bands]]
name = "80m"
start_hz = 3_500_000
end_hz = 4_000_000
default_hz = 3_700_000
bsr_code = 0x02

[[freq_ranges.ranges.bands]]
name = "60m"
start_hz = 5_330_000
end_hz = 5_410_000
default_hz = 5_357_000

[[freq_ranges.ranges.bands]]
name = "40m"
start_hz = 7_000_000
end_hz = 7_300_000
default_hz = 7_100_000
bsr_code = 0x03

[[freq_ranges.ranges.bands]]
name = "30m"
start_hz = 10_100_000
end_hz = 10_150_000
default_hz = 10_130_000
bsr_code = 0x04

[[freq_ranges.ranges.bands]]
name = "20m"
start_hz = 14_000_000
end_hz = 14_350_000
default_hz = 14_200_000
bsr_code = 0x05

[[freq_ranges.ranges.bands]]
name = "17m"
start_hz = 18_068_000
end_hz = 18_168_000
default_hz = 18_120_000
bsr_code = 0x06

[[freq_ranges.ranges.bands]]
name = "15m"
start_hz = 21_000_000
end_hz = 21_450_000
default_hz = 21_200_000
bsr_code = 0x07

[[freq_ranges.ranges.bands]]
name = "12m"
start_hz = 24_890_000
end_hz = 24_990_000
default_hz = 24_940_000
bsr_code = 0x08

[[freq_ranges.ranges.bands]]
name = "10m"
start_hz = 28_000_000
end_hz = 29_700_000
default_hz = 28_500_000
bsr_code = 0x09

[[freq_ranges.ranges]]
label = "6m"
start_hz = 50_000_000
end_hz = 54_000_000

[[freq_ranges.ranges.bands]]
name = "6m"
start_hz = 50_000_000
end_hz = 54_000_000
default_hz = 50_125_000
bsr_code = 0x0A

# ── Command 29 Routes ───────────────────────────────────────────
# Commands that use the Command29 prefix for dual-receiver targeting.
# Each entry: [command_byte, sub_byte] or [command_byte] for cmd-only (sub=None).

[cmd29]
routes = [
    [0x11],           # ATT (sub=None)
    [0x14, 0x01],     # AF Gain
    [0x14, 0x02],     # RF Gain
    [0x14, 0x03],     # SQL
    [0x14, 0x05],     # APF Type Level
    [0x14, 0x06],     # NR Level
    [0x14, 0x07],     # PBT Inner
    [0x14, 0x08],     # PBT Outer
    [0x14, 0x12],     # NB Level
    [0x14, 0x13],     # DIGI-SEL Shift
    [0x15, 0x01],     # S-meter squelch status
    [0x15, 0x05],     # Various squelch
    [0x16, 0x02],     # PREAMP
    [0x16, 0x22],     # NB
    [0x16, 0x32],     # Audio Peak Filter
    [0x16, 0x40],     # NR
    [0x16, 0x41],     # Auto Notch
    [0x16, 0x48],     # Manual Notch
    [0x16, 0x4E],     # DIGI-SEL
    [0x16, 0x4F],     # Twin Peak Filter
    [0x16, 0x56],     # Filter Shape
    [0x16, 0x65],     # IP+
    [0x1A, 0x04],     # AGC Time Constant
    [0x1A, 0x09],     # AF Mute
]

# ── CI-V Commands ────────────────────────────────────────────────
# Wire bytes as integer arrays. These are the DEFAULT command bytes
# shared across most Icom radios. Model-specific differences go in
# [commands.overrides].

[commands]
get_freq = [0x03]
set_freq = [0x05]
get_mode = [0x04]
set_mode = [0x06]
get_vfo = [0x07]
set_vfo = [0x07]
set_split = [0x0F]
get_tuning_step = [0x10]
set_tuning_step = [0x10]
get_attenuator = [0x11]
set_attenuator = [0x11]
get_antenna = [0x12]
set_antenna = [0x12]
get_speech = [0x13]
get_af_level = [0x14, 0x01]
set_af_level = [0x14, 0x01]
get_rf_gain = [0x14, 0x02]
set_rf_gain = [0x14, 0x02]
get_squelch = [0x14, 0x03]
set_squelch = [0x14, 0x03]
get_apf_type_level = [0x14, 0x05]
set_apf_type_level = [0x14, 0x05]
get_nr_level = [0x14, 0x06]
set_nr_level = [0x14, 0x06]
get_pbt_inner = [0x14, 0x07]
set_pbt_inner = [0x14, 0x07]
get_pbt_outer = [0x14, 0x08]
set_pbt_outer = [0x14, 0x08]
get_cw_pitch = [0x14, 0x09]
set_cw_pitch = [0x14, 0x09]
get_rf_power = [0x14, 0x0A]
set_rf_power = [0x14, 0x0A]
get_mic_gain = [0x14, 0x0B]
set_mic_gain = [0x14, 0x0B]
get_key_speed = [0x14, 0x0C]
set_key_speed = [0x14, 0x0C]
get_notch_filter = [0x14, 0x0D]
set_notch_filter = [0x14, 0x0D]
get_compressor_level = [0x14, 0x0E]
set_compressor_level = [0x14, 0x0E]
get_break_in_delay = [0x14, 0x0F]
set_break_in_delay = [0x14, 0x0F]
get_nb_level = [0x14, 0x12]
set_nb_level = [0x14, 0x12]
get_digisel_shift = [0x14, 0x13]
set_digisel_shift = [0x14, 0x13]
get_drive_gain = [0x14, 0x14]
set_drive_gain = [0x14, 0x14]
get_monitor_gain = [0x14, 0x15]
set_monitor_gain = [0x14, 0x15]
get_vox_gain = [0x14, 0x16]
set_vox_gain = [0x14, 0x16]
get_anti_vox_gain = [0x14, 0x17]
set_anti_vox_gain = [0x14, 0x17]
get_s_meter = [0x15, 0x02]
get_s_meter_sql_status = [0x15, 0x01]
get_various_squelch = [0x15, 0x05]
get_overflow_status = [0x15, 0x07]
get_power_meter = [0x15, 0x11]
get_swr = [0x15, 0x12]
get_alc = [0x15, 0x13]
get_comp_meter = [0x15, 0x14]
get_vd_meter = [0x15, 0x15]
get_id_meter = [0x15, 0x16]
get_preamp = [0x16, 0x02]
set_preamp = [0x16, 0x02]
get_agc = [0x16, 0x12]
set_agc = [0x16, 0x12]
get_nb = [0x16, 0x22]
set_nb = [0x16, 0x22]
get_audio_peak_filter = [0x16, 0x32]
set_audio_peak_filter = [0x16, 0x32]
get_nr = [0x16, 0x40]
set_nr = [0x16, 0x40]
get_auto_notch = [0x16, 0x41]
set_auto_notch = [0x16, 0x41]
get_manual_notch = [0x16, 0x48]
set_manual_notch = [0x16, 0x48]
get_compressor = [0x16, 0x44]
set_compressor = [0x16, 0x44]
get_monitor = [0x16, 0x45]
set_monitor = [0x16, 0x45]
get_vox = [0x16, 0x46]
set_vox = [0x16, 0x46]
get_break_in = [0x16, 0x47]
set_break_in = [0x16, 0x47]
get_digisel = [0x16, 0x4E]
set_digisel = [0x16, 0x4E]
get_twin_peak_filter = [0x16, 0x4F]
set_twin_peak_filter = [0x16, 0x4F]
get_dial_lock = [0x16, 0x50]
set_dial_lock = [0x16, 0x50]
get_filter_shape = [0x16, 0x56]
set_filter_shape = [0x16, 0x56]
get_ip_plus = [0x16, 0x65]
set_ip_plus = [0x16, 0x65]
power_on = [0x18]
power_off = [0x18]
get_transceiver_id = [0x19, 0x00]
ptt_on = [0x1C, 0x00]
ptt_off = [0x1C, 0x00]
get_ref_adjust = [0x1A, 0x05]
set_ref_adjust = [0x1A, 0x05]
get_data_mode = [0x1A, 0x06]
set_data_mode = [0x1A, 0x06]
get_af_mute = [0x1A, 0x09]
set_af_mute = [0x1A, 0x09]
get_agc_time_constant = [0x1A, 0x04]
set_agc_time_constant = [0x1A, 0x04]
get_tone_freq = [0x1B, 0x00]
set_tone_freq = [0x1B, 0x00]
get_tsql_freq = [0x1B, 0x01]
set_tsql_freq = [0x1B, 0x01]
get_rit_frequency = [0x21, 0x00]
set_rit_frequency = [0x21, 0x00]
get_rit_status = [0x21, 0x01]
set_rit_status = [0x21, 0x01]
get_rit_tx_status = [0x21, 0x02]
set_rit_tx_status = [0x21, 0x02]
send_cw = [0x17]
stop_cw = [0x17]
scope_on = [0x27, 0x10]
scope_off = [0x27, 0x10]
scope_data_output = [0x27, 0x11]
get_scope_main_sub = [0x27, 0x14]
get_scope_single_dual = [0x27, 0x15]
get_scope_mode = [0x27, 0x14]
get_scope_span = [0x27, 0x15]
get_scope_edge = [0x27, 0x16]
get_scope_hold = [0x27, 0x17]
get_scope_ref = [0x27, 0x19]
get_scope_speed = [0x27, 0x1A]
get_scope_during_tx = [0x27, 0x1B]
get_scope_center_type = [0x27, 0x1C]
